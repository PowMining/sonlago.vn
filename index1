<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sonla Go - Dành cho doanh nghiệp</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --brand-yellow: #FFC107;
            --brand-yellow-dark: #FFB300;
            --brand-green: #2E7D32;
            --text-dark: #111111;
            --text-gray: #666666;
            --bg-gray: #f8f9fa;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Montserrat', sans-serif;
        }

        body {
            color: var(--text-dark);
            line-height: 1.5;
            background-color: #ffffff;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ---------------- HEADER ---------------- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
            height: 80px;
            background-color: #ffffff;
            border-bottom: 1px solid #eeeeee;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo-container {
            font-size: 1.8rem;
            font-weight: 900;
            display: flex;
        }
        .logo-container .sonla { color: var(--text-dark); }
        .logo-container .go { color: var(--brand-yellow); margin-left: 5px; }

        .nav-links {
            display: flex;
            gap: 30px;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .nav-links a {
            padding: 28px 0;
            border-bottom: 3px solid transparent;
            transition: all 0.2s;
        }

        .nav-links a:hover, .nav-links a.active {
            color: var(--brand-yellow-dark);
            border-bottom: 3px solid var(--brand-yellow);
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .btn-download {
            background-color: var(--brand-yellow);
            color: var(--text-dark);
            font-weight: 700;
            padding: 12px 24px;
            border-radius: 4px;
            font-size: 0.9rem;
            transition: background-color 0.2s;
        }

        .btn-download:hover {
            background-color: var(--brand-yellow-dark);
        }

        .lang-switch {
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--text-gray);
        }
        .lang-switch span.active { color: var(--text-dark); }

        /* Dải phân cách vàng dưới header giống Be */
        .yellow-stripe {
            height: 40px;
            background-color: var(--brand-yellow);
            width: 100%;
        }

        /* ---------------- HERO FORM SECTION ---------------- */
        .hero-section {
            display: flex;
            max-width: 1200px;
            margin: 60px auto;
            gap: 60px;
            padding: 0 20px;
        }

        .form-container {
            flex: 1;
            background-color: var(--bg-gray);
            padding: 40px;
            border-radius: 16px;
        }

        .form-container h2 {
            margin-bottom: 30px;
            font-size: 1.8rem;
        }

        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .form-group {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--text-gray);
        }

        .form-group label span {
            color: red;
        }

        .form-group input, .form-group select {
            padding: 14px;
            border: 1px solid #dddddd;
            border-radius: 8px;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group input:focus, .form-group select:focus {
            border-color: var(--brand-green);
        }

        .terms-text {
            font-size: 0.85rem;
            text-align: center;
            margin: 20px 0;
            color: var(--text-gray);
        }

        .terms-text a {
            color: var(--brand-green);
            font-weight: 600;
        }

        .btn-submit {
            width: 100%;
            background-color: var(--brand-green);
            color: white;
            border: none;
            padding: 16px;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 30px;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn-submit:hover {
            opacity: 0.9;
        }

        .login-link {
            text-align: center;
            display: block;
            margin-top: 15px;
            font-size: 0.9rem;
        }
        .login-link a {
            color: var(--brand-green);
            font-weight: 600;
        }

        .image-container {
            flex: 1;
            border-radius: 16px;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(46,125,50,0.8), rgba(27,94,32,0.9)), url('https://images.unsplash.com/photo-1573164713988-8665fc963095?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80') center/cover;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            color: white;
            text-align: center;
        }

        .image-container h3 {
            font-size: 2.2rem;
            margin-bottom: 20px;
        }

        /* ---------------- CEO QUOTE SECTION ---------------- */
        .ceo-quote {
            background-color: var(--brand-yellow);
            padding: 80px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .quote-content {
            flex: 1;
            max-width: 600px;
        }

        .quote-content h3 {
            font-size: 1.2rem;
            color: var(--brand-green);
            margin-bottom: 5px;
        }

        .quote-content h4 {
            font-size: 1.5rem;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .quote-content p {
            font-size: 1.1rem;
            font-weight: 500;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .quote-link {
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 1.1rem;
        }

        .quote-link i {
            width: 30px;
            height: 30px;
            border: 2px solid var(--text-dark);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .big-logo {
            flex: 1;
            display: flex;
            justify-content: flex-end;
            font-size: 15rem;
            font-weight: 900;
            line-height: 0.8;
            letter-spacing: -10px;
            opacity: 0.9;
        }
        .big-logo .s { color: var(--brand-green); }
        .big-logo .g { color: var(--text-dark); }

        /* ---------------- FOOTER ---------------- */
        footer {
            padding: 60px 40px;
            background-color: #ffffff;
            border-top: 1px solid #eeeeee;
        }

        .footer-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr;
            gap: 30px;
        }

        .footer-col h5 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .footer-col ul {
            list-style: none;
        }

        .footer-col ul li {
            margin-bottom: 12px;
        }

        .footer-col ul a {
            font-size: 0.85rem;
            color: var(--text-dark);
            font-weight: 500;
        }

        .footer-col ul a:hover {
            color: var(--brand-green);
        }

        .company-info h4 {
            font-size: 1.5rem;
            font-weight: 900;
            margin-bottom: 5px;
        }

        .company-info p {
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .social-icons {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }

        .social-icons a {
            font-size: 1.5rem;
            color: var(--text-dark);
        }

        .app-badges {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .app-badges img {
            width: 120px;
            border-radius: 6px;
        }

        /* Responsive */
        @media screen and (max-width: 1024px) {
            .hero-section { flex-direction: column; }
            .ceo-quote { flex-direction: column; text-align: center; }
            .big-logo { justify-content: center; margin-top: 40px; font-size: 10rem;}
            .footer-grid { grid-template-columns: 1fr 1fr 1fr; }
        }
        @media screen and (max-width: 768px) {
            .nav-links, .lang-switch { display: none; }
            .footer-grid { grid-template-columns: 1fr 1fr; }
            .form-row { flex-direction: column; }
        }
        @media screen and (max-width: 480px) {
            .footer-grid { grid-template-columns: 1fr; }
            header { padding: 0 20px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-container">
